# Production env · set via `fly secrets set` or Railway dashboard. NEVER commit.

ENV=prod
SECRET_KEY=<openssl rand -hex 32>

# Postgres (Neon/Supabase pooled connection)
DATABASE_URL=postgresql+asyncpg://user:pw@host:5432/sellia?ssl=require

# Redis (Upstash)
REDIS_URL=rediss://default:pw@host:6379

# JWT
JWT_SECRET=<openssl rand -hex 64>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MIN=10080

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Ollama (self-hosted GPU · optional fallback)
OLLAMA_URL=https://ollama.sellia.app

# Stripe live
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# WhatsApp Cloud API
WA_VERIFY_TOKEN=<random-strong-token>
WA_APP_SECRET=<from-meta-app-dashboard>
WA_PHONE_NUMBER_ID=<from-meta>
WA_ACCESS_TOKEN=<permanent-system-user-token>

# Observability
SENTRY_DSN=https://xxx@sentry.io/yyy

# CORS (frontend domains)
CORS_ORIGINS=["https://app.sellia.app","https://sellia.app"]
