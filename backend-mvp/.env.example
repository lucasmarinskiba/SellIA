# Copy to .env and fill in
ENV=dev
SECRET_KEY=change-me-32-bytes-min-length-please

# Database (use docker-compose or your own Postgres)
DATABASE_URL=postgresql+asyncpg://sellia:sellia@localhost:5432/sellia
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=replace-me-with-strong-random-secret-256bits
JWT_ALGORITHM=HS256
JWT_EXPIRE_MIN=10080

# Anthropic (optional · falls back to Ollama)
ANTHROPIC_API_KEY=sk-ant-xxx

# Ollama local
OLLAMA_URL=http://localhost:11434

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# WhatsApp Cloud API
WA_VERIFY_TOKEN=any-strong-token-you-pick
WA_APP_SECRET=from-meta-app-dashboard
WA_PHONE_NUMBER_ID=from-meta-app-dashboard
WA_ACCESS_TOKEN=permanent-system-user-token

# Observability
SENTRY_DSN=
