# =============================================================================
# SellIA — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://ia_vendedor:YOUR_PASSWORD@db:5432/ia_vendedor
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change_this_to_a_32_char_minimum_secure_random_string
ENVIRONMENT=development

# Fernet Encryption (PII at rest) — usar una clave separada de SECRET_KEY
# Generar con: openssl rand -base64 32
FERNET_SECRET=

# Database SSL (production)
DB_SSL_MODE=prefer
DB_SSL_CA=

# AI APIs (optional — users can bring their own keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=

# MercadoPago (Argentina payments)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Payoneer (International USD payments via Checkout)
# Get these from your Payoneer developer dashboard
PAYONEER_PROGRAM_ID=
PAYONEER_CLIENT_ID=
PAYONEER_CLIENT_SECRET=
PAYONEER_WEBHOOK_SECRET=          # Optional, for webhook signature verification

# Crypto (USDT payments)
CREATOR_USDT_TRC20_ADDRESS=       # Tron network address
CREATOR_USDT_BEP20_ADDRESS=       # BSC network address
TRONGRID_API_KEY=                 # Optional, for higher TronScan rate limits
BSCSCAN_API_KEY=                  # Optional, for higher BscScan rate limits

# Creator Billing / Fiscal Info
CREATOR_MP_ALIAS=                 # e.g. lucas.marin.skiba.mp
CREATOR_COCO_ALIAS=               # e.g. LMARIN11.COCOS
CREATOR_CBU=                      # Bank CBU for wire transfers
CREATOR_CUIT=                     # e.g. 20-41941012-9
CREATOR_FULL_NAME=                # e.g. Lucas Daniel Marin
CREATOR_BUSINESS_NAME=            # Razón social (if different from full name)
CREATOR_BILLING_ADDRESS=          # e.g. Francia 2481 - Santa Fe
CREATOR_IVA_CONDITION=            # Monotributo / Responsable Inscripto / Exento

# Payoneer / International Transfer Details (for manual/invoicing)
CREATOR_PAYONEER_BANK=Citibank
CREATOR_PAYONEER_ROUTING=031100209
CREATOR_PAYONEER_SWIFT=CITIUS33
CREATOR_PAYONEER_ACCOUNT=
CREATOR_PAYONEER_BENEFICIARY=

# Frontend & Webhooks
FRONTEND_URL=http://localhost:3000
TRACKING_BASE_URL=http://localhost:8000

# Security (optional)
TURNSTILE_SECRET_KEY=

# =============================================================================
# Security & Data Isolation (PRODUCTION-GRADE)
# =============================================================================

# Rate Limiting
RATE_LIMIT_STANDARD_REQUESTS_PER_MIN=100
RATE_LIMIT_WEBHOOK_REQUESTS_PER_MIN=1000
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_BAN_MINUTES=15

# Encryption for sensitive data (API keys, credentials)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# 2FA (TOTP)
TOTP_ISSUER_NAME=SellIA
TOTP_QR_CODE_SIZE=10

# API Key Management
API_KEY_DEFAULT_EXPIRATION_DAYS=30
API_KEY_PREFIX=sk_live_

# Database Encryption
# Store this securely (e.g., AWS KMS, HashiCorp Vault)
DATABASE_ENCRYPTION_KEY=

# Audit Logging
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_BATCH_SIZE=1000

# CSRF Protection
CSRF_ENABLED=false
CSRF_TOKEN_EXPIRATION_HOURS=24

# Metrics & Monitoring
METRICS_USERNAME=prometheus
METRICS_PASSWORD=
ENABLE_OPENAPI=false

# DDoS / Bot Protection
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Security Headers
SECURITY_HEADERS_CSP=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';
SECURITY_HEADERS_HSTS_MAX_AGE=31536000
SECURITY_HEADERS_X_FRAME_OPTIONS=DENY
SECURITY_HEADERS_X_CONTENT_TYPE_OPTIONS=nosniff
